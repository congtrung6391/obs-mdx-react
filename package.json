{
  "name": "obsidian-mdx-react",
  "version": "1.0.0",
  "description": "Rendering MDX in Obsidian with React runtime.",
  "main": "main.js",
  "scripts": {
    "dev": "esbuild src/main.ts --bundle --external:obsidian --format=cjs --watch --outfile=main.js",
    "build": "esbuild src/main.ts --bundle --external:obsidian --format=cjs --minify --outfile=main.js"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "mdx",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mdx-js/mdx": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "esbuild": "^0.21.5",
    "obsidian": "^1.5.7-1",
    "typescript": "^5.4.5"
  }
}
